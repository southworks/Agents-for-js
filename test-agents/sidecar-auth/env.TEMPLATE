# Rename to .env
#
# This sample uses the Entra Agent ID sidecar auth provider. No client secret,
# certificate, or federated credential is configured: the agent is credential-free
# and delegates all token acquisition to the Microsoft Entra Agent ID
# sidecar (agent container) running alongside it.

# Select the sidecar auth provider for the default connection.
connections__serviceConnection__settings__authType=EntraAuthSideCar

# The agent (client) app id and tenant. No secret/cert is needed.
connections__serviceConnection__settings__clientId=
connections__serviceConnection__settings__tenantId=

# Base URL of the Entra Agent ID sidecar (agent container). Defaults to http://localhost:5178.
# The SIDECAR_URL environment variable, if set, takes precedence over this value.
# The host must be loopback/private unless bypassLocalNetworkRestriction is set to true.
connections__serviceConnection__settings__sidecarBaseUrl=http://localhost:5178

# Optional: sidecar downstream API names. Defaults shown.
# connections__serviceConnection__settings__serviceName=default
# connections__serviceConnection__settings__blueprintServiceName=agenticblueprint

# Optional: transport tuning. Defaults shown.
# connections__serviceConnection__settings__requestTimeout=30000
# connections__serviceConnection__settings__retryCount=3

# Optional (UNSAFE): allow a non-loopback/non-private sidecar base URL.
# connections__serviceConnection__settings__bypassLocalNetworkRestriction=false

connectionsMap__0__connection=serviceConnection
connectionsMap__0__serviceUrl=*

# Alternatively, point the SDK at the sidecar with a single environment variable
# (takes precedence over sidecarBaseUrl above):
# SIDECAR_URL=http://localhost:5178
