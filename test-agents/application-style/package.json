{
    "name": "node-application-style",
    "version": "1.0.0",
    "private": true,
    "author": "Microsoft",
    "license": "MIT",
    "main": "./dist/index.js",
    "scripts": {
    "build": "tsc --build",
    "start:anon": "node ./dist/index.js",
    "start": "npm run build && node --env-file .env ./dist/index.js",
        "test-tool": "teamsapptester start",
        "test": "npm-run-all -p -r start:anon test-tool",
    "bundle": "npm run build && esbuild ./src/index.ts --bundle --platform=node --metafile=dist/meta.json --outfile=dist/bundle.cjs --tree-shaking=true --keep-names",
    "docker": "npm run bundle && docker build -t \"$npm_package_name:$npm_package_version\" ."
    },
    "dependencies": {
        "@microsoft/agents-hosting": "file:../../packages/agents-hosting",
        "@microsoft/agents-hosting-storage-blob": "file:../../packages/agents-hosting-storage-blob",
        "@microsoft/agents-hosting-storage-cosmos": "file:../../packages/agents-hosting-storage-cosmos",
        "@microsoft/agents-activity": "file:../../packages/agents-activity",
        "express": "5.2.1",
        "express-rate-limit": "8.5.2"
    }
}
