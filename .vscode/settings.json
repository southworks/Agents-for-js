{
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },
    "nodejs-testing.extensions": [
        {
            "extensions": [
                "ts",
                "mjs"
            ],
            "parameters": [
                "--import",
                "tsx"
            ]
        }
    ],
    "nodejs-testing.include": [
        "packages/*/test/",
        "scripts/test/"
    ],
    "json.schemaDownload.trustedDomains": {
        "https://unpkg.com/": true
    }
}